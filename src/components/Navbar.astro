---
// Navbar.astro
---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent py-4 opacity-0 -translate-y-4">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-500 to-cyan-400 flex items-center justify-center font-bold text-[#030014] text-lg font-display group-hover:scale-105 transition-transform">
        A
      </div>
      <span class="font-display font-bold text-xl tracking-wider text-white group-hover:text-purple-300 transition-colors">
        AURA<span class="text-cyan-400">.</span>
      </span>
    </a>

    <!-- Nav Links (Desktop) -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-300">
      <a href="#hero" class="nav-link relative py-1 hover:text-white transition-colors">Home</a>
      <a href="#features" class="nav-link relative py-1 hover:text-white transition-colors">Features</a>
      <a href="#interactive" class="nav-link relative py-1 hover:text-white transition-colors">Interactive</a>
      <a href="#showcase" class="nav-link relative py-1 hover:text-white transition-colors">Showcase</a>
    </nav>

    <!-- Call to Action -->
    <div class="flex items-center gap-4">
      <a 
        href="#contact" 
        class="relative inline-flex items-center justify-center p-0.5 mb-2 me-2 overflow-hidden text-xs font-semibold text-white rounded-full group bg-gradient-to-br from-purple-500 to-cyan-500 group-hover:from-purple-500 group-hover:to-cyan-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-cyan-800"
      >
        <span class="relative px-4 py-1.5 transition-all ease-in duration-75 bg-[#030014] rounded-full group-hover:bg-opacity-0">
          Get Started
        </span>
      </a>
      
      <!-- Mobile Menu Button (Optional, simple trigger) -->
      <button class="md:hidden text-white focus:outline-none" id="mobile-menu-btn">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  /* Custom bottom border and background when scrolling */
  .scrolled {
    background: rgba(3, 0, 20, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  /* Hover line effect for links */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, #a78bfa, #22d3ee);
    transition: width 0.3s ease;
  }
  
  .nav-link:hover::after {
    width: 100%;
  }
</style>

<script>
  // Simple scroll header styling helper
  const header = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
