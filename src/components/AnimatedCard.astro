---
// AnimatedCard.astro
const { title = "Feature Title", description = "Feature description goes here.", iconName = "cpu" } = Astro.props;
---

<div class="glow-card glass-panel rounded-2xl p-6 md:p-8 flex flex-col gap-4 text-left group hover:scale-[1.02] duration-300">
  <!-- Dynamic SVG Icon wrapper -->
  <div class="w-12 h-12 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400 group-hover:bg-purple-500 group-hover:text-[#030014] group-hover:shadow-[0_0_15px_rgba(139,92,246,0.5)] transition-all duration-300">
    {iconName === "cpu" && (
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21M8.25 7.5h7.5A.75.75 0 0116.5 8.25v7.5a.75.75 0 01-.75.75H8.25a.75.75 0 01-.75-.75V8.25A.75.75 0 018.25 7.5z" />
      </svg>
    )}
    {iconName === "zap" && (
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
      </svg>
    )}
    {iconName === "sparkles" && (
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 21l-.813-5.096L3 15l5.096-.813L9 9l.813 5.096L15 15l-5.187.904zM18 9.05L17.5 12l-.5-2.95L14 8.5l3-1 1-3 1 3 3 1-3 1z" />
      </svg>
    )}
  </div>

  <h3 class="text-xl font-bold font-display text-white group-hover:text-purple-300 transition-colors">
    {title}
  </h3>
  
  <p class="text-sm leading-relaxed text-gray-400">
    {description}
  </p>
  
  <div class="mt-auto pt-4 flex items-center gap-2 text-xs font-semibold tracking-wider text-cyan-400 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300">
    EXPLORE MORE
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
    </svg>
  </div>
</div>
