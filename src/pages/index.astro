---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="SecurityMind Pro — AI-Native Wazuh SIEM + Compliance" 
  description="Real-time threat detection, AI-assisted triage, and audit-ready compliance — deployed on your infrastructure."
>
  <!-- ===== HEADER ===== -->
  <header id="hdr" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-sec-bg/55 border-b border-transparent transition-all duration-300 py-6">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-12">
      <!-- Logo -->
      <a class="flex items-center gap-2.5 font-extrabold text-xl tracking-tight text-white" href="#">
        <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-sec-blue-2 to-sec-blue-deep flex items-center justify-center shadow-[0_4px_18px_rgba(31,140,255,0.45)]">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L20 6V11C20 16 16.5 20.5 12 22C7.5 20.5 4 16 4 11V6L12 2Z" stroke="#fff" stroke-width="1.6" fill="rgba(255,255,255,.15)"/>
            <path d="M8.5 12L11 14.5L15.5 9.5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="flex flex-col leading-none">
          <span>SecurityMind<span class="text-sec-blue-2"> Pro</span></span>
          <span class="text-[9px] tracking-[3px] text-sec-blue-2 font-semibold mt-1">DEFEND · DETECT · COMPLY</span>
        </span>
      </a>

      <!-- SOC Live Ticker -->
      <div class="hidden md:flex items-center gap-2 text-xs py-1.5 px-3 border border-sec-line rounded-lg bg-sec-panel/60" title="Illustrative status indicator">
        <span class="text-sec-muted font-semibold">SOC</span>
        <span class="text-sec-green font-semibold flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-sec-green animate-ping"></span>
          ▲ LIVE
        </span>
        <span class="text-white font-bold ml-1">99.98% uptime</span>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href="#top" class="text-sec-muted hover:text-sec-ink transition-colors cursor-pointer">Home</a>
        <a href="#platform" class="text-sec-muted hover:text-sec-ink transition-colors cursor-pointer">Platform</a>
        <a href="#capabilities" class="text-sec-muted hover:text-sec-ink transition-colors cursor-pointer">Capabilities</a>
        <a href="#compliance" class="text-sec-muted hover:text-sec-ink transition-colors cursor-pointer">Compliance</a>
        <a href="#case-studies" class="text-sec-muted hover:text-sec-ink transition-colors cursor-pointer">Case Studies</a>
        <button class="demo-trigger-btn bg-gradient-to-r from-sec-blue-2 to-sec-blue-deep text-white px-5 py-2.5 rounded-lg shadow-[0_6px_20px_rgba(31,140,255,0.4)] hover:-translate-y-0.5 hover:shadow-[0_10px_28px_rgba(31,140,255,0.55)] transition-all cursor-pointer">
          Request a Demo
        </button>
      </nav>

      <!-- Mobile Menu Toggle -->
      <button id="mobile-menu-toggle" class="md:hidden text-sec-muted hover:text-white focus:outline-none cursor-pointer" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </header>

  <!-- ===== MOBILE NAV DRAWER ===== -->
  <div id="mobile-drawer" class="fixed inset-0 z-40 bg-sec-bg/95 backdrop-blur-lg flex flex-col pt-28 px-8 gap-6 md:hidden transition-transform duration-300 translate-x-full">
    <a href="/" class="mobile-nav-link text-xl font-bold text-sec-muted hover:text-white py-2 border-b border-sec-line">Home</a>
    <a href="#platform" class="mobile-nav-link text-xl font-bold text-sec-muted hover:text-white py-2 border-b border-sec-line">Platform</a>
    <a href="#capabilities" class="mobile-nav-link text-xl font-bold text-sec-muted hover:text-white py-2 border-b border-sec-line">Capabilities</a>
    <a href="#compliance" class="mobile-nav-link text-xl font-bold text-sec-muted hover:text-white py-2 border-b border-sec-line">Compliance</a>
    <a href="#case-studies" class="mobile-nav-link text-xl font-bold text-sec-muted hover:text-white py-2 border-b border-sec-line">Case Studies</a>
    <button class="demo-trigger-btn w-full mt-4 bg-gradient-to-r from-sec-blue-2 to-sec-blue-deep text-white font-bold py-3.5 rounded-lg shadow-lg cursor-pointer">
      Request a Demo
    </button>
  </div>

  <main class="flex-grow bg-sec-bg text-sec-ink">
    <!-- ===== HERO ===== -->
    <section class="relative pt-44 pb-24 overflow-hidden bg-[radial-gradient(1100px_520px_at_50%_-8%,rgba(31,140,255,0.28),transparent_60%),radial-gradient(700px_400px_at_80%_30%,rgba(54,212,255,0.12),transparent_60%)]">
      <!-- Background decorative rays -->
      <div class="absolute inset-0 pointer-events-none opacity-50 bg-[repeating-linear-gradient(95deg,rgba(57,160,255,0.08)_0_2px,transparent_2px_60px)] [mask-image:radial-gradient(600px_600px_at_50%_0%,#000,transparent_70%)] animate-pulse-slow"></div>
      
      <div class="max-w-7xl mx-auto px-6 text-center">
        <div class="gsap-reveal text-sec-blue-2 font-semibold text-sm tracking-wide mb-4">One Platform. Complete Threat Defense & Compliance.</div>
        <h1 class="gsap-reveal text-4xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-b from-white via-white to-[#bcd5ff] mb-6 leading-none max-w-4xl mx-auto">
          AI-Native <span class="text-transparent bg-clip-text bg-gradient-to-r from-sec-blue-2 to-sec-cyan">Wazuh SIEM</span> + Compliance
        </h1>
        <p class="gsap-reveal text-sec-muted text-base sm:text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
          Real-time threat detection, AI-assisted triage, and audit-ready compliance — deployed on your infrastructure, tuned for local regulation, and backed by hands-on consultancy and training.
        </p>
        <div class="gsap-reveal flex gap-4 justify-center flex-wrap">
          <button class="bg-gradient-to-r from-sec-blue-2 to-sec-blue-deep text-white font-bold text-sm px-7 py-3.5 rounded-lg shadow-lg hover:-translate-y-0.5 hover:shadow-[0_10px_28px_rgba(31,140,255,0.55)] transition-all cursor-pointer">
            Get My Threat Score
          </button>
          <button class="demo-trigger-btn bg-transparent border border-sec-line text-white font-bold text-sm px-7 py-3.5 rounded-lg hover:border-sec-blue hover:text-sec-blue-2 transition-all cursor-pointer">
            Book a Demo
          </button>
        </div>

        <!-- DASHBOARD MOCKUP -->
        <div class="dash-stage gsap-reveal relative mt-16 max-w-5xl mx-auto">
          <!-- Left side preview card -->
          <div class="hidden lg:block absolute left-[-60px] top-[14%] w-[200px] rounded-xl border border-sec-line bg-gradient-to-b from-[#0c1424] to-[#070d18] shadow-2xl opacity-55 scale-90 origin-right transition-transform duration-300 hover:scale-95 hover:opacity-80">
            <div class="flex items-center gap-2 p-3 border-b border-sec-line bg-sec-bg-2">
              <span class="w-3.5 h-3.5 rounded bg-gradient-to-r from-sec-blue-2 to-sec-blue-deep"></span>
              <span class="text-xs font-bold">SOC</span>
            </div>
            <div class="p-3.5 flex flex-col gap-2">
              <div class="h-2 rounded bg-sec-blue-deep/30 w-4/5"></div>
              <div class="h-2 rounded bg-sec-blue-deep/20 w-3/5"></div>
              <div class="h-14 rounded-lg bg-sec-panel mt-1.5"></div>
              <div class="h-2 rounded bg-sec-blue-deep/20 w-[70%]"></div>
              <div class="h-2 rounded bg-sec-blue-deep/20 w-[45%]"></div>
            </div>
          </div>

          <!-- Right side preview card -->
          <div class="hidden lg:block absolute right-[-60px] top-[14%] w-[200px] rounded-xl border border-sec-line bg-gradient-to-b from-[#0c1424] to-[#070d18] shadow-2xl opacity-55 scale-90 origin-left transition-transform duration-300 hover:scale-95 hover:opacity-80">
            <div class="flex items-center gap-2 p-3 border-b border-sec-line bg-sec-bg-2">
              <span class="w-3.5 h-3.5 rounded bg-gradient-to-r from-sec-blue-2 to-sec-blue-deep"></span>
              <span class="text-xs font-bold">Alerts</span>
            </div>
            <div class="p-3.5 flex flex-col gap-2">
              <div class="h-2.5 rounded bg-sec-red/20 w-[90%]"></div>
              <div class="h-2.5 rounded bg-sec-amber/20 w-[75%]"></div>
              <div class="h-2.5 rounded bg-sec-blue/20 w-[85%]"></div>
              <div class="h-2.5 rounded bg-sec-blue/20 w-[55%]"></div>
              <div class="h-2.5 rounded bg-sec-muted-2/20 w-[70%]"></div>
            </div>
          </div>

          <!-- Main Dashboard Console -->
          <div class="rounded-xl border border-sec-line bg-gradient-to-b from-[#0c1424] to-[#070d18] shadow-2xl overflow-hidden" id="dash">
            <!-- Header bar -->
            <div class="flex items-center justify-between p-3 border-b border-sec-line bg-sec-bg-2 text-xs font-semibold">
              <div class="flex items-center gap-2 text-sec-ink">
                <span class="w-4 h-4 rounded bg-gradient-to-br from-sec-blue-2 to-sec-blue-deep"></span>
                <span>SecurityMind Console</span>
              </div>
              <div class="flex-1 max-w-[300px] mx-auto h-6 rounded-md bg-sec-panel border border-sec-line"></div>
              <div class="flex gap-2">
                <span class="py-1 px-2.5 rounded bg-sec-panel border border-sec-line text-sec-muted hover:text-white cursor-pointer transition-colors">Schedule Scan</span>
                <span class="py-1 px-2.5 rounded bg-sec-panel border border-sec-line text-sec-muted hover:text-white cursor-pointer transition-colors">AI Triage</span>
              </div>
            </div>

            <!-- Grid Content -->
            <div class="grid grid-cols-[160px_1fr] min-h-[430px]">
              <!-- Sidebar -->
              <div class="border-r border-sec-line bg-[#080f1c] p-3 flex flex-col gap-1 text-xs font-semibold text-sec-muted">
                <div class="flex items-center gap-2 p-2 rounded bg-sec-blue/15 text-sec-blue-2">
                  <span class="w-3.5 h-3.5 rounded bg-sec-blue"></span>Console
                </div>
                <div class="flex items-center gap-2 p-2 rounded hover:bg-white/5 cursor-pointer transition-colors">
                  <span class="w-3.5 h-3.5 rounded bg-sec-line"></span>Insights
                </div>
                <div class="flex items-center gap-2 p-2 rounded hover:bg-white/5 cursor-pointer transition-colors">
                  <span class="w-3.5 h-3.5 rounded bg-sec-line"></span>Threat Intel
                </div>
                <div class="flex items-center gap-2 p-2 rounded hover:bg-white/5 cursor-pointer transition-colors">
                  <span class="w-3.5 h-3.5 rounded bg-sec-line"></span>Detections
                </div>
                <div class="flex items-center gap-2 p-2 rounded hover:bg-white/5 cursor-pointer transition-colors">
                  <span class="w-3.5 h-3.5 rounded bg-sec-line"></span>Compliance
                </div>
                <div class="flex items-center gap-2 p-2 rounded hover:bg-white/5 cursor-pointer transition-colors">
                  <span class="w-3.5 h-3.5 rounded bg-sec-line"></span>Agents
                </div>
                <div class="flex items-center gap-2 p-2 rounded hover:bg-white/5 cursor-pointer transition-colors">
                  <span class="w-3.5 h-3.5 rounded bg-sec-line"></span>Reports
                </div>
                <div class="flex items-center gap-2 p-2 rounded hover:bg-white/5 cursor-pointer transition-colors">
                  <span class="w-3.5 h-3.5 rounded bg-sec-line"></span>Tickets
                </div>
              </div>

              <!-- Dashboard Body -->
              <div class="p-5 flex flex-col gap-4 text-left">
                <div class="flex justify-between items-center text-sm font-semibold text-[#cfe0ff]">
                  <span>Security Operations Console</span>
                  <span class="text-[10px] text-sec-muted font-medium">Last 24h · Auto-refresh</span>
                </div>

                <!-- Grid of metrics -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3.5">
                  <!-- Posture card -->
                  <div class="bg-sec-panel border border-sec-line rounded-lg p-3.5">
                    <div class="text-[10px] font-semibold text-sec-muted mb-2 flex items-center gap-1.5">⬡ Security Posture Score</div>
                    <div class="w-28 h-28 mx-auto relative flex items-center justify-center">
                      <svg class="-rotate-90" width="110" height="110" viewBox="0 0 110 110">
                        <circle cx="55" cy="55" r="46" stroke="#13233f" stroke-width="11" fill="none"/>
                        <circle id="gaugeArc" cx="55" cy="55" r="46" stroke="url(#gg)" stroke-width="11" fill="none"
                          stroke-linecap="round" stroke-dasharray="289" stroke-dashoffset="289" />
                        <defs>
                          <linearGradient id="gg" x1="0" y1="0" x2="1" y2="1">
                            <stop offset="0" stop-color="#27d98a"/>
                            <stop offset="1" stop-color="#36d4ff"/>
                          </linearGradient>
                        </defs>
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center text-center leading-none">
                        <span class="text-2xl font-extrabold text-sec-green">8.6</span>
                        <span class="text-[9px] text-sec-muted mt-1">/ 10 healthy</span>
                      </div>
                    </div>
                  </div>

                  <!-- Donut assets card -->
                  <div class="bg-sec-panel border border-sec-line rounded-lg p-3.5">
                    <div class="text-[10px] font-semibold text-sec-muted mb-2 flex items-center gap-1.5">◷ Monitored Assets</div>
                    <div class="w-28 h-28 mx-auto relative flex items-center justify-center">
                      <svg class="-rotate-90" width="110" height="110" viewBox="0 0 110 110">
                        <circle cx="55" cy="55" r="44" stroke="#13233f" stroke-width="12" fill="none"/>
                        <circle cx="55" cy="55" r="44" stroke="#1f8cff" stroke-width="12" fill="none" stroke-dasharray="138 276"/>
                        <circle cx="55" cy="55" r="44" stroke="#36d4ff" stroke-width="12" fill="none" stroke-dasharray="83 276" stroke-dashoffset="-138"/>
                        <circle cx="55" cy="55" r="44" stroke="#7c5cff" stroke-width="12" fill="none" stroke-dasharray="55 276" stroke-dashoffset="-221"/>
                      </svg>
                      <div class="absolute inset-0 flex flex-col items-center justify-center text-center leading-none">
                        <span class="text-xl font-extrabold text-white">473</span>
                        <span class="text-[9px] text-sec-muted mt-1">endpoints</span>
                      </div>
                    </div>
                  </div>

                  <!-- Severity bar card -->
                  <div class="bg-sec-panel border border-sec-line rounded-lg p-3.5 flex flex-col justify-between">
                    <div class="text-[10px] font-semibold text-sec-muted mb-2 flex items-center gap-1.5">⚠ Alert Severity</div>
                    <div class="flex flex-col gap-2" id="expo">
                      <div class="flex items-center gap-2 text-[10px] text-sec-muted">
                        <span class="w-12 text-left">Critical</span>
                        <span class="flex-grow h-1.5 bg-sec-bg-2 rounded-full overflow-hidden">
                          <span class="fill block h-full bg-sec-red rounded-full" data-w="22%"></span>
                        </span>
                      </div>
                      <div class="flex items-center gap-2 text-[10px] text-sec-muted">
                        <span class="w-12 text-left">High</span>
                        <span class="flex-grow h-1.5 bg-sec-bg-2 rounded-full overflow-hidden">
                          <span class="fill block h-full bg-sec-amber rounded-full" data-w="38%"></span>
                        </span>
                      </div>
                      <div class="flex items-center gap-2 text-[10px] text-sec-muted">
                        <span class="w-12 text-left">Medium</span>
                        <span class="flex-grow h-1.5 bg-sec-bg-2 rounded-full overflow-hidden">
                          <span class="fill block h-full bg-sec-blue-2 rounded-full" data-w="62%"></span>
                        </span>
                      </div>
                      <div class="flex items-center gap-2 text-[10px] text-sec-muted">
                        <span class="w-12 text-left">Low</span>
                        <span class="flex-grow h-1.5 bg-sec-bg-2 rounded-full overflow-hidden">
                          <span class="fill block h-full bg-sec-green rounded-full" data-w="85%"></span>
                        </span>
                      </div>
                      <div class="flex items-center gap-2 text-[10px] text-sec-muted">
                        <span class="w-12 text-left">Info</span>
                        <span class="flex-grow h-1.5 bg-sec-bg-2 rounded-full overflow-hidden">
                          <span class="fill block h-full bg-sec-muted-2 rounded-full" data-w="95%"></span>
                        </span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Lower trend chart & stats grid -->
                <div class="grid grid-cols-1 md:grid-cols-[1.6fr_1fr] gap-4">
                  <!-- SVGs trend line -->
                  <div class="bg-sec-panel border border-sec-line rounded-lg p-3.5">
                    <div class="text-[10px] font-semibold text-[#cfe0ff] mb-2 flex justify-between items-center">
                      <span>Detection Trend</span>
                      <span class="text-sec-muted font-normal">Monthly</span>
                    </div>
                    <svg id="trendSvg" viewBox="0 0 400 120" preserveAspectRatio="none" class="w-full h-[120px] block">
                      <defs>
                        <linearGradient id="ta" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0" stop-color="rgba(57,160,255,.45)"/>
                          <stop offset="1" stop-color="rgba(57,160,255,0)"/>
                        </linearGradient>
                      </defs>
                      <path class="area-path transition-opacity duration-1000" id="areaP" fill="url(#ta)"
                        d="M0,110 C60,70 90,30 140,45 C190,60 210,15 260,25 C310,35 340,80 400,70 L400,120 L0,120 Z"/>
                      <path class="line-path" id="lineP" fill="none" stroke="#39a0ff" stroke-width="2.5"
                        d="M0,110 C60,70 90,30 140,45 C190,60 210,15 260,25 C310,35 340,80 400,70"/>
                    </svg>
                  </div>

                  <!-- Count highlights -->
                  <div class="grid grid-cols-3 gap-2">
                    <div class="bg-sec-panel border border-sec-line rounded-lg p-3 text-center flex flex-col justify-center">
                      <b class="text-xl text-white block">4,522</b>
                      <span class="text-[9px] text-sec-muted uppercase font-bold tracking-wider mt-1">Events</span>
                    </div>
                    <div class="bg-sec-panel border border-sec-line rounded-lg p-3 text-center flex flex-col justify-center">
                      <b class="text-xl text-sec-red block">38</b>
                      <span class="text-[9px] text-sec-muted uppercase font-bold tracking-wider mt-1">Critical</span>
                    </div>
                    <div class="bg-sec-panel border border-sec-line rounded-lg p-3 text-center flex flex-col justify-center">
                      <b class="text-xl text-sec-amber block">128</b>
                      <span class="text-[9px] text-sec-muted uppercase font-bold tracking-wider mt-1">High</span>
                    </div>
                    <div class="bg-sec-panel border border-sec-line rounded-lg p-3 text-center flex flex-col justify-center">
                      <b class="text-xl text-sec-blue-2 block">319</b>
                      <span class="text-[9px] text-sec-muted uppercase font-bold tracking-wider mt-1">Medium</span>
                    </div>
                    <div class="bg-sec-panel border border-sec-line rounded-lg p-3 text-center flex flex-col justify-center">
                      <b class="text-xl text-sec-green block">3,975</b>
                      <span class="text-[9px] text-sec-muted uppercase font-bold tracking-wider mt-1">Resolved</span>
                    </div>
                    <div class="bg-sec-panel border border-sec-line rounded-lg p-3 text-center flex flex-col justify-center">
                      <b class="text-xl text-purple-400 block">62</b>
                      <span class="text-[9px] text-sec-muted uppercase font-bold tracking-wider mt-1">AI Triaged</span>
                    </div>
                  </div>
                </div>

              </div>
            </div>

          </div>
        </div>

      </div>
    </section>

    <!-- ===== TRUST STRIP ===== -->
    <div class="bg-gradient-to-r from-sec-blue-2 to-sec-blue-deep overflow-hidden relative py-5 border-y border-white/10 shadow-lg">
      <div class="max-w-7xl mx-auto px-6 flex items-center gap-8">
        <span class="text-white font-black text-sm uppercase tracking-wide leading-none whitespace-nowrap">
          <span class="text-xs font-bold block opacity-75">Built for</span>
          Regulated industries
        </span>
        <div class="overflow-hidden flex-1 [mask-image:linear-gradient(90deg,transparent,#000_8%,#000_92%,transparent)]">
          <div class="flex gap-16 w-max animate-marquee">
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">BANKS</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">FINTECH</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">TELECOM</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">INSURANCE</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">GOV & PUBLIC</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">HEALTHCARE</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">E-COMMERCE</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">MFS / MOBILE MONEY</span>
            <!-- duplicate labels for circular marquee overlap loop -->
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">BANKS</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">FINTECH</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">TELECOM</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">INSURANCE</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">GOV & PUBLIC</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">HEALTHCARE</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">E-COMMERCE</span>
            <span class="text-white/95 font-extrabold text-lg tracking-wider whitespace-nowrap">MFS / MOBILE MONEY</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== PRODUCT SUITE DOME ===== -->
    <section id="platform" class="relative pt-24 pb-0 text-center overflow-hidden bg-[radial-gradient(140%_100%_at_50%_-30%,#1f8cff_0%,#0b63d6_38%,#05080f_100%)]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="gsap-reveal max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4 leading-tight">
            Cybersecurity’s Future. <span class="block text-xl md:text-2xl font-bold opacity-90 mt-2">Powered by SecurityMind Pro.</span>
          </h2>
          <p class="text-white/85 text-sm md:text-base mb-8">
            One platform for detection, response, and compliance — built on hardened open-source foundations, deployed on your infrastructure, and backed by a local team that knows your regulators.
          </p>
          <button class="bg-white text-sec-blue-deep font-extrabold text-sm px-6 py-3 rounded-lg hover:bg-gray-100 transition-colors shadow-lg cursor-pointer">
            Platform Overview
          </button>
        </div>

        <!-- Suite tabs selectors -->
