            <span class="mark w-7.5 h-7.5 rounded bg-gradient-to-br from-sec-blue-2 to-sec-blue-deep flex items-center justify-center">
              <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L20 6V11C20 16 16.5 20.5 12 22C7.5 20.5 4 16 4 11V6L12 2Z" stroke="#fff" stroke-width="1.6" fill="rgba(255,255,255,.15)"/>
                <path d="M8.5 12L11 14.5L15.5 9.5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            SecurityMind<span class="text-sec-blue-2"> Pro</span>
          </a>
          <p class="foot-about text-sec-muted text-sm leading-relaxed max-w-[34ch]">AI-assisted SOC, SIEM and compliance — deployed on your infrastructure, supported by a local team.</p>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest text-sec-muted mb-4">Platform</h5>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Detection &amp; Response</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">AI Triage</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Compliance</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Dashboards</a>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest text-sec-muted mb-4">Services</h5>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Deployment</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Audit Support</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Consultancy</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Training</a>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest text-sec-muted mb-4">Company</h5>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">About</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Careers</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Contact</a>
          <a href="#" class="block text-sec-muted-2 text-sm hover:text-sec-blue-2 mb-2 transition-colors">Blog</a>
        </div>
      </div>
      
      <div class="foot-bottom border-t border-sec-line pt-6 flex flex-col md:flex-row justify-between text-xs text-sec-muted-2 gap-4">
        <span>© 2026 SecurityMind Pro. All rights reserved.</span>
        <div class="flex gap-4">
          <a href="#" class="hover:text-sec-blue-2 transition-colors">Privacy</a>
          <a href="#" class="hover:text-sec-blue-2 transition-colors">Terms</a>
          <a href="#" class="hover:text-sec-blue-2 transition-colors">Security</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Floating Chat Bubble -->
  <div class="chatbub fixed bottom-6 right-6 z-50 w-13.5 h-13.5 rounded-full bg-gradient-to-r from-sec-blue-2 to-sec-blue flex items-center justify-center shadow-lg hover:scale-105 transition-all cursor-pointer" title="Chat with us">
    <svg class="w-6 h-6 stroke-white" viewBox="0 0 24 24" fill="none" stroke-width="1.8">
      <path d="M21 11.5a8.38 8.38 0 01-8.5 8.5 8.5 8.5 0 01-3.6-.8L3 21l1.8-5.9A8.38 8.38 0 014 11.5 8.5 8.5 0 0112.5 3 8.38 8.38 0 0121 11.5z" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- ===== DEMO BOOKING MODAL ===== -->
  <div id="demo-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-300">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/75 backdrop-blur-md"></div>
    
    <!-- Modal Card -->
    <div id="modal-card" class="relative w-full max-w-lg rounded-2xl border border-sec-line bg-[#0c1424] p-8 shadow-2xl z-10 transform scale-95 transition-all duration-300 overflow-hidden text-left">
      <!-- Glow effect -->
      <div class="absolute -top-20 -left-20 w-48 h-48 bg-sec-blue/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-20 -right-20 w-48 h-48 bg-sec-cyan/10 rounded-full blur-3xl pointer-events-none"></div>
      
      <!-- Close Button -->
      <button id="close-modal-btn" class="absolute top-4 right-4 text-sec-muted hover:text-white transition-colors cursor-pointer text-xl font-bold" aria-label="Close modal">
        &times;
      </button>
      
      <!-- Form Content -->
      <div id="modal-form-content" class="transition-all duration-300">
        <h3 class="text-2xl font-extrabold text-white mb-2 font-display">Schedule a Private Demo</h3>
        <p class="text-sec-muted text-sm mb-6 leading-relaxed">
          Experience SecurityMind Pro customized for your ICT guidelines and compliance goals.
        </p>
        
        <form id="demo-form" class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="demo-name" class="text-xs font-semibold text-sec-muted uppercase tracking-wider">Full Name</label>
            <input type="text" id="demo-name" required class="w-full bg-sec-panel border border-sec-line rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-sec-blue transition-colors" placeholder="John Doe" />
          </div>
          
          <div class="flex flex-col gap-1.5">
            <label for="demo-email" class="text-xs font-semibold text-sec-muted uppercase tracking-wider">Work Email</label>
            <input type="email" id="demo-email" required class="w-full bg-sec-panel border border-sec-line rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-sec-blue transition-colors" placeholder="john@company.com" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="demo-company" class="text-xs font-semibold text-sec-muted uppercase tracking-wider">Company Name</label>
            <input type="text" id="demo-company" required class="w-full bg-sec-panel border border-sec-line rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-sec-blue transition-colors" placeholder="ACME Bank" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="demo-interest" class="text-xs font-semibold text-sec-muted uppercase tracking-wider">Primary Focus</label>
            <select id="demo-interest" class="w-full bg-sec-panel border border-sec-line rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-sec-blue transition-colors">
              <option value="siem">AI-Native Wazuh SIEM</option>
              <option value="compliance">ComplyHub (ISO/PCI/SOC 2)</option>
              <option value="full">All Platform Capabilities</option>
              <option value="training">Consultancy &amp; Training</option>
            </select>
          </div>
          
          <button type="submit" class="mt-4 w-full bg-gradient-to-r from-sec-blue-2 to-sec-blue-deep hover:brightness-110 text-white font-bold py-3.5 rounded-lg shadow-lg hover:shadow-[0_4px_20px_rgba(31,140,255,0.45)] transition-all duration-300 cursor-pointer">
            Book My Live Session
          </button>
        </form>
      </div>
      
      <!-- Success Content (Hidden by default) -->
      <div id="modal-success-content" class="hidden flex flex-col items-center text-center py-8">
        <div class="w-16 h-16 bg-sec-green/10 border border-sec-green/30 rounded-full flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-sec-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-2xl font-extrabold text-white mb-2 font-display">Request Received!</h3>
        <p class="text-sec-muted text-sm max-w-sm mb-6 leading-relaxed">
          Thank you, <span id="success-user-name" class="text-white font-semibold"></span>. Our security engineering team will contact you at <span id="success-user-email" class="text-white font-semibold"></span> within 2 hours to coordinate your custom session.
        </p>
        <button id="success-done-btn" class="px-6 py-2.5 bg-sec-panel border border-sec-line hover:border-sec-blue text-white rounded-lg text-sm transition-all cursor-pointer">
          Done
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // --- 1. HEADER SCROLL STATE ---
  const hdr = document.getElementById('hdr');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      hdr?.classList.add('bg-sec-bg/92', 'border-sec-line', 'py-4');
      hdr?.classList.remove('bg-sec-bg/55', 'border-transparent', 'py-6');
    } else {
      hdr?.classList.remove('bg-sec-bg/92', 'border-sec-line', 'py-4');
      hdr?.classList.add('bg-sec-bg/55', 'border-transparent', 'py-6');
    }
  });

  // --- 2. GSAP SCROLL REVEAL ---
  gsap.utils.toArray('.gsap-reveal').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 28 },
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          toggleActions: 'play none none none'
        }
      }
    );
  });

  // --- 3. DASHBOARD ANIMATIONS ON VIEW ---
  // Circle Posture Score Gauge Arc
  gsap.fromTo('#gaugeArc', 
    { strokeDashoffset: 289 },
    { 
      strokeDashoffset: 289 - (289 * 0.86),
      duration: 1.6,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#dash',
        start: 'top 75%'
      }
    }
  );

  // Severity Progress Fills
  gsap.fromTo('#expo .fill',
    { width: 0 },
    {
      width: (i, el) => el.dataset.w,
      duration: 1.3,
      ease: 'power2.out',
      stagger: 0.1,
      scrollTrigger: {
        trigger: '#dash',
        start: 'top 75%'
      }
    }
  );

  // SVG Trend Chart path reveals
  gsap.fromTo('#lineP',
    { strokeDashoffset: 1400 },
    {
      strokeDashoffset: 0,
      duration: 2,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#dash',
        start: 'top 75%'
      }
    }
  );
  gsap.fromTo('#areaP',
    { opacity: 0 },
    {
      opacity: 1,
      duration: 1.5,
      delay: 0.5,
      scrollTrigger: {
        trigger: '#dash',
        start: 'top 75%'
      }
    }
  );

  // --- 4. COUNT-UP STATS ---
  const statSection = document.querySelector('.stats');
  if (statSection) {
    gsap.fromTo(statSection.querySelectorAll('[data-count]'),
      { textContent: 0 },
      {
        textContent: (i, el) => el.dataset.count,
        duration: 2,
        ease: 'power1.out',
        snap: { textContent: 1 },
        scrollTrigger: {
          trigger: statSection,
          start: 'top 80%'
        },
        onUpdate: function() {
          this.targets().forEach((el) => {
            const val = parseInt(el.textContent, 10);
            const suffix = el.dataset.suffix || '';
            el.innerHTML = val.toLocaleString() + suffix;
          });
        }
      }
    );
  }

  // --- 5. COMPLIANCE BARS ANIMATION HELPER ---
  function animComp(pane) {
    pane.querySelectorAll('.comp-anim .fill').forEach((f) => {
      gsap.killTweensOf(f);
      gsap.fromTo(f,
        { width: 0 },
        { width: f.dataset.w, duration: 1.2, ease: 'power2.out' }
      );
    });
  }

  // Trigger initial active compliance tab bars when section enters screen
  ScrollTrigger.create({
    trigger: '#tabs',
    start: 'top 80%',
    onEnter: () => {
      const activePane = document.querySelector('.tabpane.active');
      if (activePane) animComp(activePane);
    }
  });

  // --- 6. TAB LOGIC: COMPLIANCE ---
  const tabs = document.querySelectorAll('.tab');
  const panes = document.querySelectorAll('.tabpane');

  tabs.forEach((t) => {
    t.addEventListener('click', () => {
      tabs.forEach((x) => x.classList.remove('active'));
      t.classList.add('active');

      const targetPane = document.querySelector(`.tabpane[data-pane="${t.dataset.tab}"]`);
      if (targetPane) {
        panes.forEach((p) => p.classList.remove('active'));
        targetPane.classList.add('active');
        animComp(targetPane);
        
        // Quick visual snap/reveal transition
        gsap.fromTo(targetPane, 
          { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
        );
      }
    });
  });

  // --- 7. TAB LOGIC: PRODUCT SUITE ---
  const stabs = document.querySelectorAll('.stab');
  const spanes = document.querySelectorAll('.spane');

  stabs.forEach((s) => {
    s.addEventListener('click', () => {
      stabs.forEach((x) => x.classList.remove('active'));
      s.classList.add('active');

      const targetPane = document.querySelector(`.spane[data-sp="${s.dataset.s}"]`);
      if (targetPane) {
        spanes.forEach((sp) => sp.classList.remove('active'));
        targetPane.classList.add('active');

        gsap.fromTo(targetPane,
          { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
        );
      }
    });
  });

  // --- 8. CASE STUDY SWITCHING (SIDEBAR & STRIP BUTTONS) ---
  const csItems = document.querySelectorAll('.cs-item');
  const csPanes = document.querySelectorAll('.cs-pane');

  
  function showCase(index) {
    // Update selector active states
    csItems.forEach((x) => x.classList.toggle('active', x.dataset.cs === index));
    // Show corresponding pane and hide others
    csPanes.forEach((pane) => {
      if (pane.dataset.csp === index) {
        pane.classList.add('active');
        // Animate pane entrance
        gsap.fromTo(pane,
          { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
        );
      } else {
        pane.classList.remove('active');
      }
    });
  }

  document.querySelectorAll('[data-cs]').forEach((el) => {
    el.addEventListener('click', () => {
      showCase(el.dataset.cs);
    });
  });

  // --- 9. MOBILE MENU DRAWER LOGIC ---
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileDrawer = document.getElementById('mobile-drawer');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
  
  function toggleMobileMenu() {
    const isOpen = mobileDrawer?.classList.contains('translate-x-0');
    if (isOpen) {
      mobileDrawer?.classList.remove('translate-x-0');
      mobileDrawer?.classList.add('translate-x-full');
      const path = document.getElementById('hamburger-icon');
      if (path) path.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    } else {
      mobileDrawer?.classList.remove('translate-x-full');
      mobileDrawer?.classList.add('translate-x-0');
      const path = document.getElementById('hamburger-icon');
      if (path) path.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  }

  mobileToggle?.addEventListener('click', toggleMobileMenu);
  
  mobileNavLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileDrawer?.classList.remove('translate-x-0');
      mobileDrawer?.classList.add('translate-x-full');
      const path = document.getElementById('hamburger-icon');
      if (path) path.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    });
  });

  // --- 10. DEMO BOOKING MODAL LOGIC ---
  const demoModal = document.getElementById('demo-modal');
  const modalCard = document.getElementById('modal-card');
  const demoTriggers = document.querySelectorAll('.demo-trigger-btn');
  const closeModalBtn = document.getElementById('close-modal-btn');
  const modalBackdrop = document.getElementById('modal-backdrop');
  const demoForm = document.getElementById('demo-form');
  const modalFormContent = document.getElementById('modal-form-content');
  const modalSuccessContent = document.getElementById('modal-success-content');
  const successUserName = document.getElementById('success-user-name');
  const successUserEmail = document.getElementById('success-user-email');
  const successDoneBtn = document.getElementById('success-done-btn');

  function openModal() {
    document.body.style.overflow = 'hidden';
    modalFormContent?.classList.remove('hidden');
    modalSuccessContent?.classList.add('hidden');
    if (demoForm) {
      demoForm.reset();
    }

    demoModal?.classList.remove('opacity-0', 'pointer-events-none');
    
    gsap.fromTo(modalCard, 
      { scale: 0.9, opacity: 0, y: 30 },
      { scale: 1, opacity: 1, y: 0, duration: 0.5, ease: 'back.out(1.5)' }
    );
  }

  function closeModal() {
    document.body.style.overflow = '';

    gsap.to(modalCard, {
      scale: 0.95,
      opacity: 0,
      y: 20,
      duration: 0.3,
      ease: 'power2.in',
      onComplete: () => {
        demoModal?.classList.add('opacity-0', 'pointer-events-none');
      }
    });
  }

  demoTriggers.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      if (mobileDrawer?.classList.contains('translate-x-0')) {
        toggleMobileMenu();
      }
      openModal();
    });
  });

  closeModalBtn?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  successDoneBtn?.addEventListener('click', closeModal);

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !demoModal?.classList.contains('pointer-events-none')) {
      closeModal();
    }
  });

  demoForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const nameInput = document.getElementById('demo-name');
    const emailInput = document.getElementById('demo-email');
    const nameVal = nameInput ? nameInput.value : '';
    const emailVal = emailInput ? emailInput.value : '';
    
    if (successUserName) successUserName.textContent = nameVal;
    if (successUserEmail) successUserEmail.textContent = emailVal;

    gsap.to(modalFormContent, {
      opacity: 0,
      y: -10,
      duration: 0.3,
      onComplete: () => {
        modalFormContent?.classList.add('hidden');
        modalSuccessContent?.classList.remove('hidden');
        
        gsap.set(modalFormContent, { opacity: 1, y: 0 });
        
        gsap.fromTo(modalSuccessContent,
          { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
        );
      }
    });
  });
</script>
